.venv/
__pycache__/
*.pyc
.DS_Store
dist/
build/
*.egg-info/
.env
.env.*
# .claude/ holds two kinds of files:
#   - Project-shared (settings.json, hooks/, skills/) — committed so
#     any contributor / future-you gets the same hooks + skills.
#   - Machine-local (settings.local.json, credentials) — ignored.
.claude/settings.local.json
.claude/.credentials.json

# Generated outputs
downloads/
*_digest.md
*_digest_images/
*_deck.pptx
frames_*/

# Generated artifacts (uncomment if you don't want to commit samples)
*.pptx
*.mp4
*.srt

# ...but DO commit curated test fixtures. tests/compare_slides.py needs
# a stable reference deck on disk; the negation re-includes that one
# location after the *.pptx catch-all above.
!tests/fixtures/*.pptx
